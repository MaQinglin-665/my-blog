---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";

const base = import.meta.env.BASE_URL;
const hasSingleProject = projects.length === 1;
const categories = [...new Set(projects.map((project) => project.category))];
const statuses = [...new Set(projects.map((project) => project.status))];
const projectTags = [...new Set(projects.flatMap((project) => project.tags))];
const toAssetUrl = (url: string) =>
  /^https?:\/\//.test(url) ? url : `${base}${url.replace(/^\/+/, "")}`;
const heroImageUrl = `${base}images/projects/works-hero-workbench.webp`;
const previewImages = projects.slice(0, 3).map((project) => ({
  project,
  src: toAssetUrl(project.demoImageUrl ?? project.coverUrl)
}));
---

<BaseLayout
  title="项目作品 | MQL Blog"
  description="MQL 的项目作品集，展示正在构建和持续迭代的 AI 作品。"
>
  <section class="page-hero works-hero">
    <img
      class="works-hero-image"
      src={heroImageUrl}
      alt=""
      aria-hidden="true"
      loading="eager"
    />
    <div class="works-hero-shade" aria-hidden="true"></div>

    <a href={base} class="back-link works-back-link">
      <span aria-hidden="true">&larr;</span>
      返回首页
    </a>

    <div class="works-hero-layout">
      <div class="works-hero-copy">
        <p class="works-kicker">项目作品集</p>
        <h1 class="works-title">
          可试玩 AI 作品索引
        </h1>
        <p class="works-subtitle">
          每个项目都按作品展示：它解决什么问题、处在哪个阶段、用了哪些技术，以及哪里可以继续查看。
        </p>

        <div class="works-hero-stats" aria-label="项目概览">
          <span><strong>{projects.length}</strong> 项目</span>
          <span><strong>{categories.length}</strong> 分类</span>
          <span><strong>{projectTags.length}</strong> 标签</span>
        </div>

        <aside class="works-hero-board" aria-label="项目预览">
          <div class="works-board-head">
            <span>作品预览</span>
            <strong>{projects.length} 个项目</strong>
          </div>

          <div class="works-preview-stack">
            {previewImages.map((item, index) => (
              <a
                href={`${base}projects/${item.project.slug}/`}
                class:list={["works-preview-card", index === 0 && "works-preview-card-primary"]}
                style={`--preview-index:${index}; --project-hue:${item.project.accentHue};`}
              >
                <img src={item.src} alt={`${item.project.title} 预览`} loading="eager" />
                <span>{item.project.status}</span>
                <strong>{item.project.title}</strong>
              </a>
            ))}
          </div>

          <div class="works-board-foot">
            <span>当前方向</span>
            <strong>{categories.join(" / ")}</strong>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="filter-panel" aria-label="项目筛选">
    <div>
      <p class="section-title">筛选</p>
      <div class="filter-row" data-project-filters>
        <button class="filter-button filter-button-active" type="button" data-filter-type="all" data-filter-value="all" aria-pressed="true">
          全部项目
        </button>
        {categories.map((category) => (
          <button class="filter-button" type="button" data-filter-type="category" data-filter-value={category} aria-pressed="false">
            {category}
          </button>
        ))}
        {statuses.map((status) => (
          <button class="filter-button" type="button" data-filter-type="status" data-filter-value={status} aria-pressed="false">
            {status}
          </button>
        ))}
        {projectTags.slice(0, 6).map((tag) => (
          <button class="filter-button" type="button" data-filter-type="tag" data-filter-value={tag} aria-pressed="false">
            {tag}
          </button>
        ))}
      </div>
    </div>
    <p class="filter-count" data-project-count aria-live="polite">{projects.length} 个项目</p>
  </section>

  <section class:list={["project-grid", hasSingleProject && "project-grid-single"]}>
    {projects.map((project, index) => (
      <div
        class="fade-up"
        data-delay={String((index % 3) + 1)}
        data-project-item
        data-category={project.category}
        data-status={project.status}
        data-tags={project.tags.join("|")}
      >
        <ProjectCard project={project} />
      </div>
    ))}
  </section>

  <script is:inline>
    (() => {
      const buttons = [...document.querySelectorAll("[data-project-filters] button")];
      const items = [...document.querySelectorAll("[data-project-item]")];
      const count = document.querySelector("[data-project-count]");

      if (buttons.length === 0 || items.length === 0) return;

      const setActive = (target) => {
        buttons.forEach((button) => {
          const active = button === target;
          button.classList.toggle("filter-button-active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      };

      const matches = (item, type, value) => {
        if (type === "all") return true;
        if (type === "category") return item.dataset.category === value;
        if (type === "status") return item.dataset.status === value;
        if (type === "tag") return (item.dataset.tags || "").split("|").includes(value);
        return true;
      };

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const type = button.dataset.filterType || "all";
          const value = button.dataset.filterValue || "all";
          let visible = 0;

          setActive(button);
          items.forEach((item) => {
            const show = matches(item, type, value);
            item.hidden = !show;
            if (show) visible += 1;
          });

          if (count) {
            count.textContent = `${visible} 个项目`;
          }
        });
      });
    })();
  </script>
</BaseLayout>

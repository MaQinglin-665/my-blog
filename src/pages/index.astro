---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { getAllPosts, getAllTags } from "../lib/notion";

const posts = await getAllPosts();
const tags = await getAllTags();
const base = import.meta.env.BASE_URL;
const featuredPost = posts[0] ?? null;
const feedPosts = posts.length > 1 ? posts.slice(1) : [];
const featuredUrl = featuredPost ? `${base}blog/${featuredPost.slug}/` : null;
const featuredDate = featuredPost
  ? new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(
      new Date(featuredPost.publishedAt)
    )
  : null;
---

<BaseLayout
  title="Home | MQL Blog"
  description="一个由 Astro + Notion 驱动的个人博客，记录开发、思考和日常。"
>
  <section class="hero-panel fade-up">
    <div class="grid gap-8 lg:grid-cols-[1.35fr_1fr] lg:items-end">
      <div>
        <p class="hero-kicker">PERSONAL PUBLISHING SYSTEM</p>
        <h1 class="hero-title">在 Notion 写作，在博客长期沉淀内容</h1>
        <p class="hero-subtitle">
          用更轻的写作流程，持续发布真正有价值的内容。技术复盘、项目日志、日常思考，都能稳定沉淀。
        </p>

        <div class="hero-actions">
          {featuredUrl ? (
            <a class="cta-button" href={featuredUrl}>阅读最新文章</a>
          ) : (
            <a class="cta-button" href="#posts">查看文章列表</a>
          )}
          <a class="ghost-button" href="#tags">查看标签</a>
          <span class="floating-pill">Auto deploy every 5 min</span>
        </div>

        <div class="hero-metrics">
          <span class="metric-chip">Published: {posts.length}</span>
          <span class="metric-chip">Tags: {tags.length}</span>
          <span class="metric-chip">
            Workflow: Notion → Astro → GitHub Pages
          </span>
        </div>
      </div>

      <aside class="hero-sidecard">
        <p class="section-title">Current Focus</p>
        <p class="mt-2 text-xl font-semibold text-slate-900 dark:text-slate-100">
          {featuredPost ? featuredPost.title : "准备发布你的第一篇文章"}
        </p>
        <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
          {featuredPost
            ? featuredPost.summary || "最新文章已同步到站点，点击即可继续阅读。"
            : "在 Notion 中把 Status 设置为 Published，站点会自动生成页面。"}
        </p>
        {featuredUrl && (
          <a class="cta-button mt-4 w-full sm:w-auto" href={featuredUrl}>Open Latest</a>
        )}
      </aside>
    </div>
  </section>

  {featuredPost && (
    <section class="featured-panel fade-up" data-delay="1">
      <div class="featured-layout">
        <a class="featured-cover" href={featuredUrl!}>
          {featuredPost.coverUrl ? (
            <img class="featured-image" src={featuredPost.coverUrl} alt={`${featuredPost.title} cover`} />
          ) : (
            <div class="flex h-full w-full items-end bg-gradient-to-br from-cyan-100 via-sky-50 to-amber-50 p-6 dark:from-cyan-900/40 dark:via-slate-900 dark:to-amber-900/30">
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-300">
                Featured Article
              </span>
            </div>
          )}
          <div class="featured-overlay"></div>
        </a>

        <div class="featured-content">
          <p class="section-title">Featured Post</p>
          <h2 class="featured-title">{featuredPost.title}</h2>
          {featuredDate && (
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{featuredDate}</p>
          )}
          <p class="featured-summary">
            {featuredPost.summary || "点击进入阅读完整内容。"}
          </p>
          <a class="cta-button mt-5" href={featuredUrl!}>Read Featured</a>
        </div>
      </div>
    </section>
  )}

  <section id="tags" class="section-panel fade-up" data-delay="2">
    <div class="flex items-center justify-between gap-4">
      <h2 class="section-title">Tag Navigator</h2>
      {tags.length > 0 && (
        <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
          点击标签快速筛选文章
        </span>
      )}
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">
          还没有标签，发布文章后会自动生成。
        </p>
      ) : (
        tags.map((tag) => (
          <TagBadge tag={tag} href={`${base}tags/${encodeURIComponent(tag)}/`} />
        ))
      )}
    </div>
  </section>

  <section id="posts" class="mt-10 fade-up" data-delay="3">
    <div class="mb-5">
      <p class="section-title">Latest Posts</p>
      <h2 class="section-heading">最近更新</h2>
    </div>

    <div class="post-grid">
      {posts.length === 0 ? (
        <div class="empty-state">
          还没有可展示的文章。请在 Notion 数据库中新建文章，并把 <strong>Status</strong> 设为 <strong>Published</strong>。
        </div>
      ) : feedPosts.length === 0 ? (
        <div class="empty-state">当前只有一篇文章，已在上方精选展示。</div>
      ) : (
        feedPosts.map((post, index) => (
          <div class="fade-up" data-delay={String((index % 3) + 1)}>
            <PostCard post={post} />
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

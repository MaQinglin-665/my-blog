---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { featuredProjects, projects } from "../data/projects";
import { getAllPosts, getAllTags } from "../lib/notion";

const posts = await getAllPosts();
const tags = await getAllTags();
const base = import.meta.env.BASE_URL;
const featuredPost = posts[0] ?? null;
const feedPosts = posts.length > 1 ? posts.slice(1) : [];
const featuredUrl = featuredPost ? `${base}blog/${featuredPost.slug}/` : null;
const previewProjects = (featuredProjects.length > 0 ? featuredProjects : projects).slice(0, 2);
const spotlightProject = previewProjects[0] ?? null;
const featuredDate = featuredPost
  ? new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(
      new Date(featuredPost.publishedAt)
    )
  : null;
---

<BaseLayout
  title="MQL Blog | 写作与项目"
  description="MQL 的个人博客与项目展示，记录开发、AI 实践、作品迭代和日常思考。"
>
  <section class="hero-panel fade-up">
    <div class="grid gap-8 lg:grid-cols-[1.35fr_1fr] lg:items-end">
      <div>
        <p class="hero-kicker">WRITING / PROJECTS / NOTES</p>
        <h1 class="hero-title">把写作、项目和复盘放在同一个现场</h1>
        <p class="hero-subtitle">
          这里记录正在做的项目、解决问题的过程，以及值得长期保存的思考。文章负责沉淀，项目负责展示，复盘让每次迭代都有回声。
        </p>

        <div class="hero-actions">
          {featuredUrl ? (
            <a class="cta-button" href={featuredUrl}>阅读最新文章</a>
          ) : (
            <a class="cta-button" href="#posts">查看文章列表</a>
          )}
          <a class="ghost-button" href={`${base}projects/`}>查看项目</a>
          <a class="ghost-button" href="#tags">查看标签</a>
          <span class="floating-pill">Auto deploy every 5 min</span>
        </div>

        <div class="hero-metrics">
          <span class="metric-chip">Posts: {posts.length}</span>
          <span class="metric-chip">Projects: {projects.length}</span>
          <span class="metric-chip">Tags: {tags.length}</span>
          <span class="metric-chip">
            Workflow: Notion → Astro → GitHub Pages
          </span>
        </div>
      </div>

      <aside class="hero-sidecard">
        <p class="section-title">Project Spotlight</p>
        <p class="mt-2 text-xl font-semibold text-slate-900 dark:text-slate-100">
          {spotlightProject ? spotlightProject.title : "准备发布你的第一个项目"}
        </p>
        <p class="mt-3 text-sm leading-7 text-slate-600 dark:text-slate-300">
          {spotlightProject
            ? spotlightProject.summary
            : "把项目名称、链接和亮点写进项目数据后，首页会自动展示。"}
        </p>
        {spotlightProject && (
          <a
            class="cta-button mt-4 w-full sm:w-auto"
            href={spotlightProject.links[0].href}
            target="_blank"
            rel="noreferrer"
          >
            打开项目
          </a>
        )}
      </aside>
    </div>
  </section>

  <section id="projects" class="mt-6 fade-up" data-delay="1">
    <div class="mb-5 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="section-title">Project Portfolio</p>
        <h2 class="section-heading">正在打磨的项目</h2>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300">
          把 GitHub 项目放进博客首页，让访客能先看到你正在构建什么，再进入文章了解过程。
        </p>
      </div>
      <a class="ghost-button w-full sm:w-auto" href={`${base}projects/`}>查看全部项目</a>
    </div>

    <div class="project-grid">
      {previewProjects.map((project, index) => (
        <div class="fade-up" data-delay={String((index % 2) + 1)}>
          <ProjectCard project={project} compact />
        </div>
      ))}
    </div>
  </section>

  {featuredPost && (
    <section class="featured-panel fade-up" data-delay="2">
      <div class="featured-layout">
        <a class="featured-cover" href={featuredUrl!}>
          {featuredPost.coverUrl ? (
            <img class="featured-image" src={featuredPost.coverUrl} alt={`${featuredPost.title} cover`} />
          ) : (
            <div class="flex h-full w-full items-end bg-gradient-to-br from-cyan-100 via-sky-50 to-amber-50 p-6 dark:from-cyan-900/40 dark:via-slate-900 dark:to-amber-900/30">
              <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-300">
                Featured Article
              </span>
            </div>
          )}
          <div class="featured-overlay"></div>
        </a>

        <div class="featured-content">
          <p class="section-title">Featured Post</p>
          <h2 class="featured-title">{featuredPost.title}</h2>
          {featuredDate && (
            <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">{featuredDate}</p>
          )}
          <p class="featured-summary">
            {featuredPost.summary || "点击进入阅读完整内容。"}
          </p>
          <a class="cta-button mt-5" href={featuredUrl!}>Read Featured</a>
        </div>
      </div>
    </section>
  )}

  <section id="tags" class="section-panel fade-up" data-delay="3">
    <div class="flex items-center justify-between gap-4">
      <h2 class="section-title">Tag Navigator</h2>
      {tags.length > 0 && (
        <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
          点击标签快速筛选文章
        </span>
      )}
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">
          还没有标签，发布文章后会自动生成。
        </p>
      ) : (
        tags.map((tag) => (
          <TagBadge tag={tag} href={`${base}tags/${encodeURIComponent(tag)}/`} />
        ))
      )}
    </div>
  </section>

  <section id="posts" class="mt-10 fade-up" data-delay="4">
    <div class="mb-5">
      <p class="section-title">Latest Posts</p>
      <h2 class="section-heading">最近更新</h2>
    </div>

    <div class="post-grid">
      {posts.length === 0 ? (
        <div class="empty-state">
          还没有可展示的文章。请在 Notion 数据库中新建文章，并把 <strong>Status</strong> 设为 <strong>Published</strong>。
        </div>
      ) : feedPosts.length === 0 ? (
        <div class="empty-state">当前只有一篇文章，已在上方精选展示。</div>
      ) : (
        feedPosts.map((post, index) => (
          <div class="fade-up" data-delay={String((index % 3) + 1)}>
            <PostCard post={post} />
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

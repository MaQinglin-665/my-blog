---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { getAllPosts, getAllTags } from "../lib/notion";

const posts = await getAllPosts();
const tags = await getAllTags();
const base = import.meta.env.BASE_URL;
const latestPost = posts[0];
---

<BaseLayout
  title="Home | My Blog"
  description="A personal blog powered by Astro + Notion API, with modern layout and dark mode."
>
  <section class="hero-panel fade-up">
    <p class="section-title">Journal • Ideas • Build Notes</p>
    <h1 class="hero-title">写点能被时间留下来的内容。</h1>
    <p class="hero-subtitle">
      这是你的个人内容主场。每篇文章在 Notion 写完后，都会自动同步为静态页面，清爽、快速、长期可维护。
    </p>

    <div class="hero-metrics">
      <span class="metric-chip">Published: {posts.length}</span>
      <span class="metric-chip">Tags: {tags.length}</span>
      <span class="metric-chip">
        Latest: {latestPost ? latestPost.title : "No post yet"}
      </span>
    </div>
  </section>

  <section class="section-panel fade-up" data-delay="1">
    <div class="flex items-center justify-between gap-4">
      <h2 class="section-title">Tag Navigator</h2>
      {tags.length > 0 && (
        <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
          点击标签筛选文章
        </span>
      )}
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">还没有标签，写下第一篇文章后会自动生成。</p>
      ) : (
        tags.map((tag) => (
          <TagBadge tag={tag} href={`${base}tags/${encodeURIComponent(tag)}/`} />
        ))
      )}
    </div>
  </section>

  <section id="posts" class="mt-10 fade-up" data-delay="2">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="section-title">Latest Posts</p>
        <h2 class="mt-1 text-3xl font-semibold text-slate-900 dark:text-slate-100 sm:text-4xl">
          最近更新
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {posts.length === 0 ? (
        <div class="empty-state">
          还没有可展示的文章。请在 Notion 中创建文章并将 <strong>Status</strong> 设为
          <strong>Published</strong>。
        </div>
      ) : (
        posts.map((post, index) => (
          <div class="fade-up" data-delay={String((index % 3) + 1)}>
            <PostCard post={post} />
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { getAllPosts, getAllTags } from "../lib/notion";

const posts = await getAllPosts();
const tags = await getAllTags();
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="首页 | My Blog" description="使用 Astro + Notion API 构建的个人博客。">
  <section class="mb-10">
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100">
      博客文章
    </h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">
      所有内容来自 Notion 数据库，构建时自动同步为静态页面。
    </p>
  </section>

  <section class="mb-10">
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      标签
    </h2>
    <div class="flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">暂无标签</p>
      ) : (
        tags.map((tag) => (
          <TagBadge tag={tag} href={`${base}tags/${encodeURIComponent(tag)}/`} />
        ))
      )}
    </div>
  </section>

  <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {posts.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-slate-300 p-8 text-sm text-slate-500 dark:border-slate-700 dark:text-slate-400">
        还没有可展示的文章。请在 Notion 中创建文章并将 Status 设为 Published。
      </div>
    ) : (
      posts.map((post) => <PostCard post={post} />)
    )}
  </section>
</BaseLayout>

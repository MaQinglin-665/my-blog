---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import TagBadge from "../components/TagBadge.astro";
import { getAllPosts, getAllTags } from "../lib/notion";

const posts = await getAllPosts();
const tags = await getAllTags();
const base = import.meta.env.BASE_URL;
const latestPost = posts[0];
const latestPostUrl = latestPost ? `${base}blog/${latestPost.slug}/` : null;
---

<BaseLayout
  title="Home | MQL Blog"
  description="一个由 Astro + Notion 驱动的个人博客，记录开发、思考和日常。"
>
  <section class="hero-panel fade-up">
    <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr] lg:items-end">
      <div>
        <p class="hero-kicker">PERSONAL PUBLISHING SYSTEM</p>
        <h1 class="hero-title">在 Notion 写作，在博客优雅发布</h1>
        <p class="hero-subtitle">
          这里是你的内容主场。把想法、项目复盘和生活记录沉淀成长期可访问的文章，持续输出，持续成长。
        </p>

        <div class="hero-metrics">
          <span class="metric-chip">Published: {posts.length}</span>
          <span class="metric-chip">Tags: {tags.length}</span>
          <span class="metric-chip">
            Updated: {latestPost ? latestPost.publishedAt : "No post yet"}
          </span>
        </div>
      </div>

      <aside class="hero-sidecard">
        <p class="section-title">Latest Highlight</p>
        <p class="mt-2 text-xl font-semibold text-slate-900 dark:text-slate-100">
          {latestPost ? latestPost.title : "准备发布你的第一篇文章"}
        </p>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">
          {latestPost
            ? latestPost.summary || "最新文章已同步到站点，点击即可阅读。"
            : "在 Notion 中把 Status 设为 Published，站点会自动生成页面。"}
        </p>
        {latestPostUrl && (
          <a class="cta-button mt-4 w-full sm:w-auto" href={latestPostUrl}>
            阅读最新文章
          </a>
        )}
      </aside>
    </div>
  </section>

  <section class="section-panel fade-up" data-delay="1">
    <div class="flex items-center justify-between gap-4">
      <h2 class="section-title">Tag Navigator</h2>
      {tags.length > 0 && (
        <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
          点击标签快速筛选文章
        </span>
      )}
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.length === 0 ? (
        <p class="text-sm text-slate-500 dark:text-slate-400">还没有标签，发布文章后会自动生成。</p>
      ) : (
        tags.map((tag) => (
          <TagBadge tag={tag} href={`${base}tags/${encodeURIComponent(tag)}/`} />
        ))
      )}
    </div>
  </section>

  <section id="posts" class="mt-10 fade-up" data-delay="2">
    <div class="mb-5 flex items-end justify-between gap-4">
      <div>
        <p class="section-title">Latest Posts</p>
        <h2 class="mt-1 text-3xl font-semibold text-slate-900 dark:text-slate-100 sm:text-4xl">
          最近更新
        </h2>
      </div>
    </div>

    <div class="post-grid">
      {posts.length === 0 ? (
        <div class="empty-state">
          还没有可展示的文章。请在 Notion 数据库中新建文章，并把 <strong>Status</strong> 设为 <strong>Published</strong>。
        </div>
      ) : (
        posts.map((post, index) => (
          <div class="fade-up" data-delay={String((index % 3) + 1)}>
            <PostCard post={post} />
          </div>
        ))
      )}
    </div>
  </section>
</BaseLayout>

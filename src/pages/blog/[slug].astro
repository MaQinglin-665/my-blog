---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagBadge from "../../components/TagBadge.astro";
import type { Post } from "../../lib/notion";
import { getAllPosts, getPostContent } from "../../lib/notion";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const markdown = await getPostContent(post.id);
const markdownProcessor = await createMarkdownProcessor({
  syntaxHighlight: {
    type: "shiki"
  },
  shikiConfig: {
    theme: "github-light",
    themes: {
      light: "github-light",
      dark: "github-dark"
    },
    wrap: true
  }
});
const { code: renderedHtml } = await markdownProcessor.render(markdown);
const published = new Date(post.publishedAt);
const displayDate = Number.isNaN(published.getTime())
  ? post.publishedAt
  : new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(published);
---

<BaseLayout
  title={`${post.title} | MQL Blog`}
  description={post.summary || `${post.title} - 博客文章`}
  ogImage={post.coverUrl}
>
  <article class="mx-auto w-full max-w-3xl">
    <a
      href={import.meta.env.BASE_URL}
      class="mb-6 inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200"
    >
      <span aria-hidden="true">&larr;</span>
      返回首页
    </a>

    {post.coverUrl && (
      <figure class="mb-8 overflow-hidden rounded-2xl bg-slate-100 dark:bg-slate-900">
        <img
          src={post.coverUrl}
          alt={`${post.title} cover`}
          class="h-auto w-full scale-[1.01] object-cover"
          loading="eager"
        />
      </figure>
    )}

    <header class="mb-8 border-b border-slate-200 pb-6 dark:border-slate-800">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100">
        {post.title}
      </h1>
      <div class="mt-3 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={post.publishedAt}>{displayDate}</time>
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <TagBadge tag={tag} href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`} />
        ))}
      </div>
    </header>

    <div class="content-prose" set:html={renderedHtml}></div>
  </article>
</BaseLayout>

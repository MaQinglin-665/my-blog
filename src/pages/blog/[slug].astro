---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TagBadge from "../../components/TagBadge.astro";
import type { Post } from "../../lib/notion";
import { getAllPosts, getPostContent } from "../../lib/notion";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const markdown = await getPostContent(post.id);
const markdownProcessor = await createMarkdownProcessor({
  syntaxHighlight: {
    type: "shiki"
  },
  shikiConfig: {
    theme: "github-light",
    themes: {
      light: "github-light",
      dark: "github-dark"
    },
    wrap: true
  }
});
const { code: renderedHtml } = await markdownProcessor.render(markdown);
const published = new Date(post.publishedAt);
const displayDate = Number.isNaN(published.getTime())
  ? post.publishedAt
  : new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(published);
---

<BaseLayout
  title={`${post.title} | MQL Blog`}
  description={post.summary || `${post.title} - 博客文章`}
  ogImage={post.coverUrl}
>
  <article class="mx-auto w-full max-w-4xl">
    <div class="page-hero">
      <a href={import.meta.env.BASE_URL} class="back-link">
        <span aria-hidden="true">&larr;</span>
        返回首页
      </a>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-slate-900 sm:text-5xl dark:text-slate-100">
        {post.title}
      </h1>
      <div class="mt-4 flex flex-wrap items-center gap-2 text-sm text-slate-500 dark:text-slate-400">
        <time datetime={post.publishedAt}>{displayDate}</time>
        <span>·</span>
        <span>Notion Synced</span>
      </div>
      {post.tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {post.tags.map((tag) => (
            <TagBadge tag={tag} href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`} />
          ))}
        </div>
      )}
    </div>

    <div class="reading-surface">
      {post.coverUrl && (
        <figure class="article-cover mb-8">
          <img
            src={post.coverUrl}
            alt={`${post.title} cover`}
            class="article-cover-image"
            loading="eager"
          />
        </figure>
      )}

      <div class="content-prose" set:html={renderedHtml}></div>
    </div>
  </article>
</BaseLayout>

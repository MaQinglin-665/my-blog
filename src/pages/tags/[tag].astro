---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import type { Post } from "../../lib/notion";
import { getAllPosts } from "../../lib/notion";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const map = new Map<string, Post[]>();

  for (const post of posts) {
    for (const tag of post.tags) {
      const list = map.get(tag) ?? [];
      list.push(post);
      map.set(tag, list);
    }
  }

  return [...map.entries()].map(([tag, tagPosts]) => ({
    params: { tag: encodeURIComponent(tag) },
    props: { tag, posts: tagPosts }
  }));
}

interface Props {
  tag: string;
  posts: Post[];
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`${tag} | 标签页`} description={`查看标签「${tag}」下的所有文章`}>
  <section class="mb-8">
    <a
      href={import.meta.env.BASE_URL}
      class="mb-4 inline-flex items-center text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200"
    >
      ← 返回首页
    </a>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100">
      标签：{tag}
    </h1>
    <p class="mt-2 text-slate-600 dark:text-slate-300">共 {posts.length} 篇文章</p>
  </section>

  <section class="grid grid-cols-1 gap-5 md:grid-cols-2">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>

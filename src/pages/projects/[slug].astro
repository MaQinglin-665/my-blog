---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects, type Project } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const toProjectAssetSrc = (url: string) =>
  /^https?:\/\//.test(url) ? url : `${base}${url.replace(/^\/+/, "")}`;
const coverSrc = toProjectAssetSrc(project.coverUrl);
const showcaseImageUrl = project.demoImageUrl ?? project.coverUrl;
const showcaseImageSrc = toProjectAssetSrc(showcaseImageUrl);
const isPhoneShowcase = project.demoImageVariant === "phone";
const galleryItems = project.gallery ?? [];
const style = `--project-hue:${project.accentHue};`;
const projectFacts = [
  { label: "阶段", value: project.status },
  { label: "方向", value: project.category },
  { label: "技术", value: project.language },
  { label: "年份", value: project.year }
];
const primaryLink = project.links[0] ?? null;
---

<BaseLayout
  title={`${project.title} | 项目详情`}
  description={project.summary}
  ogImage={coverSrc}
>
  <article class="project-detail" style={style}>
    <section class="project-detail-hero">
      <div>
        <a href={`${base}projects/`} class="back-link">
          <span aria-hidden="true">&larr;</span>
          返回项目列表
        </a>
        <p class="section-title mt-6">Work Detail / 项目详情</p>
        <h1 class="mt-3 text-4xl font-semibold leading-tight text-slate-900 dark:text-slate-100 sm:text-6xl">
          {project.title}
        </h1>
        <p class="mt-5 max-w-3xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg">
          {project.summary}
        </p>

        <div class="project-detail-meta">
          <span>{project.category}</span>
          <span>{project.status}</span>
          <span>{project.language}</span>
          <span>{project.year}</span>
          <time datetime={project.updatedAt}>更新于 {project.updatedAt}</time>
        </div>

        <div class="project-detail-actions">
          <a href="#showcase">View Showcase / 成果展示</a>
          {project.links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
          ))}
        </div>
      </div>

      <figure class="project-detail-cover">
        <img src={coverSrc} alt={`${project.title} 封面`} loading="eager" />
      </figure>
    </section>

    <section id="showcase" class:list={["project-showcase-panel", isPhoneShowcase && "project-showcase-panel-phone"]}>
      <div class:list={["project-showcase-visual", isPhoneShowcase && "project-showcase-visual-phone"]}>
        <img src={showcaseImageSrc} alt={`${project.title} 实机演示截图`} loading="eager" />
        {!isPhoneShowcase && (
          <div class="project-showcase-overlay">
            <span>{project.status}</span>
            <strong>{project.title}</strong>
          </div>
        )}
      </div>

      <div class="project-showcase-content">
        <p class="section-title">Showcase / 成果展示</p>
        <h2>From idea to verifiable work</h2>
        <p>
          这里先看这个作品已经成型的部分：它处在哪个阶段、主要解决什么问题、现在最值得点进去看的内容是什么。
        </p>

        <div class="project-fact-grid">
          {projectFacts.map((fact) => (
            <div>
              <span>{fact.label}</span>
              <strong>{fact.value}</strong>
            </div>
          ))}
        </div>

        <div class="project-proof-list" aria-label={`${project.title} 可验证亮点`}>
          {project.highlights.slice(0, 3).map((highlight, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <p>{highlight}</p>
            </article>
          ))}
        </div>

        <div class="project-showcase-actions">
          {primaryLink && (
            <a href={primaryLink.href} target="_blank" rel="noreferrer">
              Open {primaryLink.label}
            </a>
          )}
          <a href="#details">Read build notes / 实现拆解</a>
        </div>
      </div>
    </section>

    <section class="project-detail-grid">
      <div id="details" class="reading-surface project-detail-main">
        <p class="section-title">Build Context / 作品介绍</p>
        <p class="mt-4 text-base leading-8 text-slate-700 dark:text-slate-200">
          {project.description}
        </p>

        <div class="project-detail-sections">
          {project.detailSections.map((section) => (
            <section>
              <h2>{section.title}</h2>
              <p>{section.body}</p>
            </section>
          ))}
        </div>

        {project.aiSystem && (
          <section class="project-ai-system-section">
            <div class="project-section-heading-row">
              <div>
                <p class="section-title">AI 决策与发言系统</p>
                <h2>让判断、行动和发言对得上</h2>
              </div>
              <span>{project.aiSystem.points.length} 个关键设计</span>
            </div>
            <p class="project-ai-system-intro">{project.aiSystem.intro}</p>

            <div class="project-ai-system-grid">
              {project.aiSystem.points.map((point) => (
                <article class="project-ai-system-card">
                  <h3>{point.title}</h3>
                  <p>{point.body}</p>
                  <div>
                    {point.terms.map((term) => (
                      <span>{term}</span>
                    ))}
                  </div>
                </article>
              ))}
            </div>

            <ol class="project-ai-flow">
              {project.aiSystem.flow.map((item) => (
                <li>
                  <span>{item.label}</span>
                  <p>{item.body}</p>
                </li>
              ))}
            </ol>
          </section>
        )}

        {galleryItems.length > 0 && (
          <section class="project-gallery-section">
            <div class="project-section-heading-row">
              <div>
                <p class="section-title">Gallery / 真实截图</p>
                <h2>真实页面与关键状态</h2>
              </div>
              <span>{galleryItems.length} 张截图</span>
            </div>
            <div class="project-gallery-grid">
              {galleryItems.map((item) => (
                <article class="project-gallery-card">
                  <img src={toProjectAssetSrc(item.imageUrl)} alt={`${project.title} ${item.title} 场景图`} loading="lazy" />
                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}

        <section class="project-module-section">
          <div class="project-section-heading-row">
            <p class="section-title">核心模块</p>
            <span>{project.modules.length} 个模块</span>
          </div>
          <div class="project-module-grid">
            {project.modules.map((module) => (
              <article class="project-module-card">
                <h2>{module.title}</h2>
                <p>{module.body}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="project-timeline-section">
          <div class="project-section-heading-row">
            <p class="section-title">开发时间线</p>
            <span>持续迭代</span>
          </div>
          <ol class="project-timeline">
            {project.timeline.map((item) => (
              <li>
                <time>{item.date}</time>
                <div>
                  <h2>{item.title}</h2>
                  <p>{item.body}</p>
                </div>
              </li>
            ))}
          </ol>
        </section>
      </div>

      <aside class="project-detail-sidebar">
        <section>
          <p class="section-title">亮点</p>
          <ul class="project-highlights mt-4">
            {project.highlights.map((highlight) => (
              <li>{highlight}</li>
            ))}
          </ul>
        </section>

        <section>
          <p class="section-title">标签</p>
          <div class="project-tags">
            {project.tags.map((tag) => (
              <span>{tag}</span>
            ))}
          </div>
        </section>

        <section>
          <p class="section-title">问题与解决</p>
          <div class="project-challenge-list">
            {project.challenges.map((challenge) => (
              <article>
                <h2>{challenge.problem}</h2>
                <p>{challenge.solution}</p>
              </article>
            ))}
          </div>
        </section>

        <section>
          <p class="section-title">下一步</p>
          <ul class="project-next-list">
            {project.nextSteps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </section>
      </aside>
    </section>
  </article>
</BaseLayout>

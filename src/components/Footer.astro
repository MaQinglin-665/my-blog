---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="mt-16 border-t border-slate-200/70 pb-10 pt-10 dark:border-slate-800/80">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="footer-panel">
      <div>
        <p class="text-base font-semibold text-slate-800 dark:text-slate-100">MQL Portfolio</p>
        <p class="mt-2">
          AI works, field notes, and topic indexes in one static Astro site.
        </p>
        <p class="mt-2 text-xs text-slate-500 dark:text-slate-500">
          {year} MQL Blog. 保留所有权利。
        </p>
      </div>

      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
          Navigation
        </p>
        <div class="mt-3 flex flex-col gap-2">
          <a class="hover:text-slate-900 dark:hover:text-white" href={base}>Home / 首页</a>
          <a class="hover:text-slate-900 dark:hover:text-white" href={`${base}projects/`}>Works / 项目</a>
          <a class="hover:text-slate-900 dark:hover:text-white" href={`${base}#posts`}>Notes / 文章</a>
          <a class="hover:text-slate-900 dark:hover:text-white" href={`${base}#tags`}>Topics / 标签</a>
        </div>
      </div>

      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-400">
          Site Structure
        </p>
        <div class="mt-3 flex flex-col gap-2">
          <p>Project-first portfolio</p>
          <p>Notion-synced writing</p>
          <p>Topic-based reading paths</p>
          <p>Published through GitHub Pages</p>
        </div>
      </div>
    </div>
  </div>
</footer>

---
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-40 border-b border-slate-200/65 bg-white/78 backdrop-blur-xl dark:border-slate-800/85 dark:bg-slate-950/78">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href={base} class="group inline-flex flex-col gap-1">
      <span class="text-[0.65rem] font-semibold uppercase tracking-[0.22em] text-slate-500 transition-colors group-hover:text-slate-700 dark:text-slate-400 dark:group-hover:text-slate-200">
        Personal Publishing
      </span>
      <span class="text-lg font-semibold text-slate-900 dark:text-slate-100 sm:text-xl">MQL Blog</span>
    </a>

    <div class="flex items-center gap-2 rounded-full border border-slate-200/80 bg-white/85 p-1 dark:border-slate-700/70 dark:bg-slate-900/75">
      <a
        href={base}
        class="rounded-full px-3 py-1 text-sm font-medium text-slate-600 hover:bg-slate-200/70 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white"
      >
        Home
      </a>
      <a
        href={`${base}#posts`}
        class="hidden rounded-full px-3 py-1 text-sm font-medium text-slate-600 hover:bg-slate-200/70 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-white sm:inline-flex"
      >
        Posts
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

---
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith("/") ? base : `${base}/`;
const currentPath = Astro.url.pathname;
const homePath = normalizedBase;
const isHome = currentPath === homePath || currentPath === homePath.slice(0, -1);
const isBlog = currentPath.includes(`${normalizedBase}blog/`);
const isProjects = currentPath.includes(`${normalizedBase}projects`);
const isTags = currentPath.includes(`${normalizedBase}tags/`);

function navClass(active: boolean) {
  return `nav-pill ${active ? "nav-pill-active" : ""}`;
}
---

<header class="sticky top-0 z-40 border-b border-slate-200/65 bg-white/78 backdrop-blur-xl dark:border-slate-800/85 dark:bg-slate-950/78">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-4 py-3 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <a href={base} class="group inline-flex min-w-0 items-center gap-3">
      <span class="brand-mark" aria-hidden="true">
        <span>M</span>
      </span>
      <span class="inline-flex min-w-0 flex-col gap-0.5">
        <span class="truncate text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-slate-500 transition-colors group-hover:text-cyan-700 dark:text-slate-400 dark:group-hover:text-cyan-200">
          AI Works / Notes
        </span>
        <span class="truncate text-lg font-semibold text-slate-900 dark:text-slate-100 sm:text-xl">MQL Portfolio</span>
      </span>
    </a>

    <div class="topbar-panel flex w-full items-center gap-2 lg:w-auto">
      <a href={base} class={navClass(isHome)}>Home</a>
      <a href={`${base}projects/`} class={navClass(isProjects)}>Works</a>
      <a href={`${base}#posts`} class={navClass(isBlog)}>Notes</a>
      <a href={`${base}#about`} class={navClass(false)}>About</a>
      <a href={`${base}#tags`} class={navClass(isTags)}>Topics</a>
      <ThemeToggle />
    </div>
  </div>

  <div class="scroll-progress-track">
    <div id="scroll-progress" class="scroll-progress-fill"></div>
  </div>
</header>

<script is:inline>
  (() => {
    const progress = document.querySelector("#scroll-progress");
    if (!progress) return;

    const update = () => {
      const root = document.documentElement;
      const max = root.scrollHeight - root.clientHeight;
      const ratio = max > 0 ? (root.scrollTop / max) * 100 : 0;
      progress.style.width = `${Math.min(Math.max(ratio, 0), 100)}%`;
    };

    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
  })();
</script>

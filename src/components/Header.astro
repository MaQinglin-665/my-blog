---
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/85 backdrop-blur dark:border-slate-800 dark:bg-slate-950/80">
  <div class="mx-auto flex w-full max-w-5xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href={base} class="text-lg font-semibold tracking-tight text-slate-900 dark:text-slate-100">
      My Blog
    </a>
    <div class="flex items-center gap-4">
      <a href={base} class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
        首页
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

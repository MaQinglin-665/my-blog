---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
const style = `--project-hue:${project.accentHue};`;
const detailUrl = `${import.meta.env.BASE_URL}projects/${project.slug}/`;
const isRemoteCover = /^https?:\/\//.test(project.coverUrl);
const coverSrc = isRemoteCover
  ? project.coverUrl
  : `${import.meta.env.BASE_URL}${project.coverUrl.replace(/^\/+/, "")}`;
---

<article class:list={["project-card group", compact && "project-card-compact"]} style={style}>
  <a class="project-cover" href={detailUrl}>
    <img
      src={coverSrc}
      alt={`${project.title} 封面`}
      loading="lazy"
      class="project-cover-image"
    />
    <span class="project-status">{project.status}</span>
    <span class="project-category-chip">{project.category}</span>
  </a>

  <div class="project-body">
    <div class="project-meta-row">
      <span>{project.category}</span>
      <span aria-hidden="true">/</span>
      <span>{project.language}</span>
      <span aria-hidden="true">/</span>
      <span>{project.year}</span>
      <span aria-hidden="true">/</span>
      <time datetime={project.updatedAt}>{project.updatedAt}</time>
    </div>

    <h3 class="project-title">
      <a href={detailUrl}>{project.title}</a>
    </h3>

    <p class="project-summary">{compact ? project.summary : project.description}</p>

    {!compact && project.highlights.length > 0 && (
      <ul class="project-highlights" aria-label={`${project.title} 亮点`}>
        {project.highlights.map((highlight) => (
          <li>{highlight}</li>
        ))}
      </ul>
    )}

    <div class="project-tags">
      {project.tags.map((tag) => (
        <span>{tag}</span>
      ))}
    </div>

    <div class="project-actions">
      <a href={detailUrl}>查看详情</a>
      {project.links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>
      ))}
    </div>
  </div>
</article>

---
import type { Post } from "../lib/notion";
import TagBadge from "./TagBadge.astro";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const postUrl = `${import.meta.env.BASE_URL}blog/${post.slug}/`;
const published = new Date(post.publishedAt);
const displayDate = Number.isNaN(published.getTime())
  ? post.publishedAt
  : new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(published);
---

<article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-card dark:border-slate-800 dark:bg-slate-900/80">
  <div class="mb-3 text-sm text-slate-500 dark:text-slate-400">
    <time datetime={post.publishedAt}>{displayDate}</time>
  </div>
  <h2 class="text-xl font-semibold leading-tight text-slate-900 dark:text-slate-100">
    <a href={postUrl} class="hover:text-slate-700 dark:hover:text-white">
      {post.title}
    </a>
  </h2>
  <p class="mt-3 text-sm text-slate-600 dark:text-slate-300">{post.summary}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    {post.tags.map((tag) => (
      <TagBadge tag={tag} href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`} />
    ))}
  </div>
</article>

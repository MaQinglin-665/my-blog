---
import type { Post } from "../lib/notion";

interface Props {
  post: Post;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const postUrl = `${import.meta.env.BASE_URL}blog/${post.slug}/`;
const published = new Date(post.publishedAt);
const displayDate = Number.isNaN(published.getTime())
  ? post.publishedAt
  : new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(published);
const year = Number.isNaN(published.getTime()) ? "NOTE" : String(published.getFullYear());
const shortDate = Number.isNaN(published.getTime())
  ? "NOTE"
  : new Intl.DateTimeFormat("zh-CN", {
      month: "2-digit",
      day: "2-digit"
    }).format(published);
const hasTags = post.tags.length > 0;
const primaryTag = post.tags[0] ?? "日志";
const displayTags = hasTags ? post.tags.slice(0, 3) : ["日志"];
const featuredImageUrl = `${import.meta.env.BASE_URL}images/posts/field-notes-featured.webp`;
---

<article class:list={["post-card group", featured && "post-card-featured"]}>
  <div class="post-date-block" aria-hidden="true">
    <span>{year}</span>
    <strong>{shortDate}</strong>
    {featured && <em>最新</em>}
  </div>

  <div class:list={["post-category-cell", featured && "post-image-cell"]}>
    {featured ? (
      <a class="post-featured-image" href={postUrl} aria-label={`阅读 ${post.title}`}>
        <img
          src={featuredImageUrl}
          alt=""
          aria-hidden="true"
          loading="lazy"
        />
      </a>
    ) : (
      <>
        <span class="post-category-mark" aria-hidden="true"></span>
        <strong>{primaryTag}</strong>
      </>
    )}
  </div>

  <div class="post-card-content">
    <div class="post-meta-row">
      {featured && <span>工程实践</span>}
      <span>{primaryTag}</span>
      <time datetime={post.publishedAt}>{displayDate}</time>
    </div>

    <h2 class="post-card-title">
      <a href={postUrl}>{post.title}</a>
    </h2>

    <p class="post-note-paper">
      {post.summary || "还没有摘要，点进文章阅读全文。"}
    </p>
  </div>

  <div class="post-tag-row">
    {displayTags.map((tag) => (
      hasTags ? (
        <a class="post-file-tag" href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`}>
          {tag}
        </a>
      ) : (
        <span class="post-file-tag">{tag}</span>
      )
    ))}
  </div>

  <div class="post-read-cell">
    <a
      href={postUrl}
      class="post-bookmark-link"
    >
      Read note
      <span aria-hidden="true">&rarr;</span>
    </a>
    <span class="post-path-label">/blog/{post.slug}</span>
  </div>
</article>

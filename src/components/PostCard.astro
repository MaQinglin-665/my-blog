---
import type { Post } from "../lib/notion";
import TagBadge from "./TagBadge.astro";

interface Props {
  post: Post;
}

const { post } = Astro.props;
const postUrl = `${import.meta.env.BASE_URL}blog/${post.slug}/`;
const published = new Date(post.publishedAt);
const displayDate = Number.isNaN(published.getTime())
  ? post.publishedAt
  : new Intl.DateTimeFormat("zh-CN", { dateStyle: "long" }).format(published);
---

<article class="group rounded-3xl border border-slate-200/75 bg-white/82 p-6 shadow-lg shadow-slate-900/5 backdrop-blur-sm transition-all duration-300 hover:-translate-y-1.5 hover:border-slate-300 hover:shadow-xl hover:shadow-slate-900/10 dark:border-slate-800/80 dark:bg-slate-900/65 dark:shadow-black/25 dark:hover:border-slate-700">
  {post.coverUrl && (
    <a
      href={postUrl}
      class="post-cover-shell mb-5 block"
    >
      <img
        src={post.coverUrl}
        alt={`${post.title} cover`}
        loading="lazy"
        class="post-cover-image transition-transform duration-500 group-hover:scale-[1.14]"
      />
      <div class="post-cover-overlay"></div>
    </a>
  )}
  {!post.coverUrl && (
    <a
      href={postUrl}
      class="mb-5 flex aspect-[16/7.7] items-end overflow-hidden rounded-2xl bg-gradient-to-br from-cyan-100 via-sky-50 to-amber-50 p-4 dark:from-cyan-900/40 dark:via-slate-900 dark:to-amber-900/30"
    >
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500 dark:text-slate-300">
        No Cover Image
      </span>
    </a>
  )}

  <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">
    <span class="h-1.5 w-1.5 rounded-full bg-cyan-500/80"></span>
    <time datetime={post.publishedAt}>{displayDate}</time>
  </div>

  <h2 class="mt-3 text-2xl font-semibold leading-tight text-slate-900 transition-colors group-hover:text-slate-700 dark:text-slate-100 dark:group-hover:text-white">
    <a href={postUrl}>{post.title}</a>
  </h2>

  <p class="mt-3 min-h-[5.25rem] text-sm leading-7 text-slate-600 dark:text-slate-300">
    {post.summary || "No summary yet. Open this post to read the full story."}
  </p>

  <div class="mt-5 flex flex-wrap gap-2">
    {post.tags.map((tag) => (
      <TagBadge tag={tag} href={`${import.meta.env.BASE_URL}tags/${encodeURIComponent(tag)}/`} />
    ))}
  </div>

  <div class="mt-6 flex items-center justify-between gap-3">
    <a
      href={postUrl}
      class="inline-flex items-center gap-2 rounded-full border border-slate-300/80 px-3 py-1.5 text-sm font-semibold text-slate-700 transition-all hover:-translate-y-0.5 hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:text-white"
    >
      Read Article
      <span aria-hidden="true">&rarr;</span>
    </a>
    <span class="text-xs font-medium text-slate-500 dark:text-slate-400">
      /blog/{post.slug}
    </span>
  </div>
</article>
